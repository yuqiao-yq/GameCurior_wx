/* components/empty-state/empty-state.wxss */
.empty-state {
  padding: 140rpx 60rpx;
  text-align: center;
}

.empty-state--compact {
  padding: 80rpx 60rpx;
}

.empty-state__icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.55;
  line-height: 1;
}

.empty-state--compact .empty-state__icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-state__title {
  font-size: 30rpx;
  color: #1f2329;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-state__desc {
  font-size: 26rpx;
  color: #86909c;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.empty-state__btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  font-weight: 500;
  transition: opacity 0.15s, transform 0.15s;
}

.empty-state__btn--primary {
  background: linear-gradient(135deg, #667eea 0%, #5b3aa8 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(91, 58, 168, 0.25);
}

.empty-state__btn--outline {
  border: 2rpx solid #5b3aa8;
  color: #5b3aa8;
  background: #ffffff;
}

.empty-state__btn--hover {
  opacity: 0.85;
  transform: scale(0.98);
}
