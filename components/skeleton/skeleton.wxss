/* components/skeleton/skeleton.wxss */

/* ============ 基础色块 ============ */
.sk-block,
.sk-line,
.sk-pill {
  background: #ebedf0;
  border-radius: 8rpx;
  position: relative;
  overflow: hidden;
}

/* shimmer 闪烁动画（仅当 animated=true 时启用） */
.skeleton--animated .sk-block::after,
.skeleton--animated .sk-line::after,
.skeleton--animated .sk-pill::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.6) 50%,
    transparent 100%
  );
  transform: translateX(-100%);
  animation: skeleton-shimmer 1.4s ease-in-out infinite;
}

@keyframes skeleton-shimmer {
  0%   { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* ============ 文本行 ============ */
.sk-line {
  height: 28rpx;
  margin-bottom: 16rpx;
}

.sk-line--title {
  height: 36rpx;
  width: 60%;
  margin-bottom: 20rpx;
}

.sk-line--lg {
  height: 48rpx;
  width: 70%;
}

.sk-line--meta {
  width: 40%;
  margin-bottom: 24rpx;
}

.sk-line--desc {
  height: 22rpx;
}

.sk-line--short {
  width: 50%;
}

.sk-line--narrow {
  width: 60%;
  margin: 16rpx auto 0;
}

/* ============ 标签胶囊 ============ */
.sk-pill {
  display: inline-block;
  width: 100rpx;
  height: 36rpx;
  border-radius: 18rpx;
  margin-right: 12rpx;
}

.sk-pill--narrow {
  width: 60rpx;
}

/* ============ 模式 1：列表 ============ */
.sk-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 24rpx 32rpx;
}

.sk-card {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.04);
}

.sk-card__cover {
  width: 160rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.sk-card__body {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.sk-card__meta {
  margin-top: 16rpx;
}

/* ============ 模式 2：详情 ============ */
.sk-detail {
  background: #ffffff;
  min-height: 100vh;
}

.sk-detail__header {
  width: 100%;
  height: 480rpx;
  border-radius: 0;
}

.sk-detail__body {
  padding: 32rpx;
}

.sk-detail__tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.sk-detail__screenshots {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
  overflow: hidden;
}

.sk-shot {
  width: 320rpx;
  height: 180rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
}

/* ============ 模式 3：九宫格 ============ */
.sk-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 0 24rpx;
}

.sk-grid__cell {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 0 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(31, 35, 41, 0.04);
}

.sk-grid__icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin: 0 auto;
}
