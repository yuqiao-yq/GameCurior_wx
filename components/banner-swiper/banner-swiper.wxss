/* components/banner-swiper/banner-swiper.wxss */
.banner {
  width: 100%;
  overflow: hidden;
}

.banner--rounded {
  border-radius: 20rpx;
}

.banner__swiper {
  width: 100%;
  height: 260rpx;
}

.banner__slide {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  /* fallback 颜色（无图无渐变） */
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.banner__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* 半透明渐变蒙层，保证文字可读性 */
.banner__mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    rgba(0, 0, 0, 0.45) 0%,
    rgba(0, 0, 0, 0.15) 60%,
    rgba(0, 0, 0, 0) 100%
  );
}

.banner__content {
  position: relative;
  z-index: 2;
  height: 100%;
  padding: 36rpx 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  color: #ffffff;
}

.banner__title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.banner__subtitle {
  font-size: 24rpx;
  opacity: 0.92;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.25);
}
