/* pages/mine/mine.wxss */
.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding-bottom: 80rpx;
}

/* ============ 头部 ============ */
.header {
  position: relative;
  padding: 60rpx 40rpx 80rpx 40rpx;
  overflow: hidden;
}

.header__bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-bottom-left-radius: 32rpx;
  border-bottom-right-radius: 32rpx;
}

.header__content {
  position: relative;
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.avatar-btn {
  width: 140rpx;
  height: 140rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  border-radius: 50%;
  overflow: hidden;
  line-height: 0;
}

.avatar-btn::after {
  border: none;
}

.avatar-btn--hover {
  opacity: 0.8;
  transform: scale(0.98);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background: #ffffff;
}

.user-info {
  flex: 1;
  min-width: 0;
  color: #ffffff;
  padding: 8rpx 0;
  border-radius: 12rpx;
}

.user-info--hover {
  background: rgba(255, 255, 255, 0.08);
}

.user-info__name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-info__edit {
  font-size: 24rpx;
  opacity: 0.7;
  padding: 4rpx 10rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 8rpx;
}

.user-info__openid {
  font-size: 20rpx;
  opacity: 0.7;
  word-break: break-all;
}

/* ============ 数据统计 ============ */
.stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #ffffff;
  margin: -40rpx 24rpx 0 24rpx;
  padding: 32rpx 0;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.08);
  position: relative;
  z-index: 2;
}

.stats__item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
}

.stats__item--hover {
  opacity: 0.7;
}

.stats__num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2329;
  margin-bottom: 8rpx;
}

.stats__label {
  font-size: 24rpx;
  color: #86909c;
}

.stats__divider {
  width: 1rpx;
  height: 60rpx;
  background: #f2f3f5;
}

/* ============ 菜单 ============ */
.menu {
  margin: 32rpx 24rpx 0 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu__item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f7f8fa;
  font-size: 28rpx;
  color: #1f2329;
}

.menu__item:last-child {
  border-bottom: none;
}

.menu__item--hover {
  background: #f7f8fa;
}

.menu__icon {
  width: 48rpx;
  height: 48rpx;
  font-size: 32rpx;
  text-align: center;
  line-height: 48rpx;
  margin-right: 20rpx;
}

.menu__title {
  flex: 1;
}

.menu__arrow {
  color: #c9cdd4;
  font-size: 36rpx;
}

/* ============ 底部 ============ */
.footer {
  margin-top: 60rpx;
  text-align: center;
  font-size: 22rpx;
  color: #a9aeb8;
}
