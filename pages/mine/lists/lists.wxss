/* pages/mine/lists/lists.wxss */
.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 32rpx 24rpx 80rpx;
}

/* Header */
.header {
  padding: 24rpx 12rpx 32rpx;
}

.header__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2329;
  margin-bottom: 8rpx;
}

.header__desc {
  font-size: 24rpx;
  color: #86909c;
}

/* 创建按钮 */
.create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #5b3aa8 100%);
  color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 58, 168, 0.25);
  font-size: 30rpx;
  font-weight: 600;
}

.create-btn--hover {
  opacity: 0.85;
  transform: scale(0.98);
}

.create-btn__plus {
  font-size: 40rpx;
  line-height: 1;
}

/* 清单卡片网格（双列） */
.list-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.list-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.05);
}

.list-card--hover {
  transform: scale(0.97);
  opacity: 0.92;
}

.list-card__cover-wrap {
  position: relative;
  width: 100%;
  padding-top: 75%; /* 4:3 比例 */
}

.list-card__cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  background: #f2f3f5;
}

.list-card__cover--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.list-card__cover-icon {
  font-size: 80rpx;
  opacity: 0.8;
  color: #ffffff;
}

.list-card__badge {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 6rpx 14rpx;
  font-size: 20rpx;
  color: #ffffff;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 16rpx;
  backdrop-filter: blur(8rpx);
}

.list-card__body {
  padding: 20rpx 20rpx 24rpx;
}

.list-card__name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.list-card__desc {
  font-size: 22rpx;
  color: #86909c;
  line-height: 1.4;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  min-height: 60rpx;
}

.loading {
  grid-column: span 2;
  padding: 40rpx 0;
  text-align: center;
  color: #86909c;
  font-size: 26rpx;
}

.tips {
  margin-top: 32rpx;
  text-align: center;
  font-size: 22rpx;
  color: #a9aeb8;
}
