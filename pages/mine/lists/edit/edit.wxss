/* pages/mine/lists/edit/edit.wxss */
.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding-bottom: 200rpx;
}

/* ============ 封面区 ============ */
.cover-section {
  padding: 32rpx;
}

.cover-wrap {
  position: relative;
  width: 100%;
  padding-top: 56.25%; /* 16:9 */
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.05);
}

.cover-wrap--hover {
  opacity: 0.92;
}

.cover-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #f2f4ff 0%, #e7e9ff 100%);
  color: #5b3aa8;
}

.cover-placeholder__icon {
  font-size: 80rpx;
  opacity: 0.6;
}

.cover-placeholder__text {
  font-size: 28rpx;
  font-weight: 600;
}

.cover-placeholder__hint {
  font-size: 22rpx;
  color: #86909c;
}

.cover-actions {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  display: flex;
  gap: 12rpx;
}

.cover-action {
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  color: #ffffff;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.cover-action--del {
  background: rgba(245, 63, 63, 0.85);
}

.cover-tips {
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: #86909c;
}

/* ============ 表单 ============ */
.form {
  background: #ffffff;
  margin: 0 32rpx;
  border-radius: 20rpx;
  padding: 8rpx 32rpx;
}

.field {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f6f7fb;
  position: relative;
}

.field:last-child {
  border-bottom: none;
}

.field__label {
  font-size: 26rpx;
  color: #4e5969;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.field__required {
  color: #f53f3f;
  margin-left: 4rpx;
}

.field__input {
  width: 100%;
  font-size: 30rpx;
  color: #1f2329;
  padding: 8rpx 0;
  min-height: 56rpx;
}

.field__textarea {
  width: 100%;
  font-size: 28rpx;
  color: #1f2329;
  padding: 8rpx 0;
  min-height: 120rpx;
  line-height: 1.6;
}

.field__count {
  position: absolute;
  right: 0;
  bottom: 8rpx;
  font-size: 22rpx;
  color: #a9aeb8;
}

/* ============ 提交 ============ */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f2f3f5;
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #5b3aa8 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 6rpx 16rpx rgba(91, 58, 168, 0.25);
  box-sizing: border-box;
}

.submit-btn--hover {
  opacity: 0.88;
  transform: scale(0.99);
}

.submit-btn--disabled {
  opacity: 0.5;
  pointer-events: none;
}
