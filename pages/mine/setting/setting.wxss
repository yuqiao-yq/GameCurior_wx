/* pages/mine/setting/setting.wxss */
.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding-bottom: 60rpx;
}

.group {
  margin-top: 32rpx;
}

.group__title {
  padding: 0 32rpx 16rpx;
  font-size: 24rpx;
  color: #86909c;
  font-weight: 500;
}

.group__list {
  background: #ffffff;
  border-radius: 0;
}

.row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f6f7fb;
}

.row:last-child {
  border-bottom: none;
}

.row--hover {
  background: #fafbff;
}

.row__icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.row__label {
  flex: 1;
  font-size: 30rpx;
  color: #1f2329;
}

.row__extra {
  font-size: 26rpx;
  color: #86909c;
  margin-right: 8rpx;
}

.row__arrow {
  font-size: 36rpx;
  color: #c9cdd4;
  margin-left: 8rpx;
}

.footer {
  margin-top: 80rpx;
  text-align: center;
  font-size: 22rpx;
  color: #a9aeb8;
}
