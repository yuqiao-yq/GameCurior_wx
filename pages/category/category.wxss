/* pages/category/category.wxss */
.page { min-height: 100vh; background: #f6f7fb; padding-bottom: 40rpx; }

.header { padding: 48rpx 32rpx 32rpx; }
.header__title { font-size: 40rpx; font-weight: 700; color: #1f2329; margin-bottom: 8rpx; }
.header__desc { font-size: 26rpx; color: #86909c; }

.loading {
  padding: 200rpx 0;
  text-align: center;
  color: #86909c;
  font-size: 28rpx;
}

.empty {
  padding: 160rpx 0;
  text-align: center;
}
.empty__icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty__text { font-size: 30rpx; color: #1f2329; font-weight: 600; margin-bottom: 8rpx; }
.empty__hint { font-size: 22rpx; color: #86909c; padding: 0 60rpx; }

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 0 24rpx;
}

.cat-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(31, 35, 41, 0.04);
}
.cat-card--hover {
  transform: scale(0.96);
  opacity: 0.85;
}
.cat-card__icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
.cat-card__name {
  font-size: 26rpx;
  font-weight: 500;
  color: #1f2329;
}
