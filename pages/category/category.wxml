<!--pages/category/category.wxml-->
<privacy-popup />

<view class="page">
  <view class="header">
    <view class="header__title">游戏分类</view>
    <view class="header__desc">按类型寻找你喜欢的好游戏</view>
  </view>

  <skeleton wx:if="{{ loading }}" type="grid" count="9" />

  <empty-state
    wx:elif="{{ categories.length === 0 }}"
    type="empty"
    title="还没有分类数据"
    desc="请先在云开发控制台跑 initGames 云函数"
  />

  <view wx:else class="grid">
    <view
      class="cat-card"
      wx:for="{{ categories }}"
      wx:key="_id"
      data-id="{{ item._id }}"
      data-name="{{ item.name }}"
      bindtap="handleCategoryTap"
      hover-class="cat-card--hover"
    >
      <view class="cat-card__icon">{{ item.icon }}</view>
      <view class="cat-card__name">{{ item.name }}</view>
    </view>
  </view>
</view>
