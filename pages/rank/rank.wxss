/* pages/rank/rank.wxss */
.page { min-height: 100vh; background: #f6f7fb; padding-bottom: 40rpx; }

.tabs {
  display: flex;
  background: #ffffff;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #f2f3f5;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #4e5969;
  position: relative;
}
.tab--active {
  color: #5b3aa8;
  font-weight: 600;
}
.tab--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #5b3aa8;
  border-radius: 2rpx;
}

.hero {
  margin: 24rpx;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 20rpx;
  text-align: center;
}
.hero__icon { font-size: 80rpx; margin-bottom: 16rpx; }
.hero__title { font-size: 36rpx; font-weight: 700; margin-bottom: 8rpx; }
.hero__desc { font-size: 24rpx; opacity: 0.85; }

.empty {
  padding: 200rpx 0;
  text-align: center;
}
.empty__icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty__text { font-size: 30rpx; color: #1f2329; font-weight: 600; margin-bottom: 8rpx; }
.empty__hint { font-size: 24rpx; color: #86909c; }
