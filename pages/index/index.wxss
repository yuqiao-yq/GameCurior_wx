/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

/* ============ Banner 轮播 ============ */
.banner-wrap {
  margin-bottom: 24rpx;
}

.banner-wrap--skeleton {
  height: 260rpx;
  background: linear-gradient(135deg, #ebedf0 0%, #d8dadf 100%);
  border-radius: 20rpx;
  opacity: 0.5;
}

/* ============ 顶部搜索框 ============ */
.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.05);
}

.search-bar--hover {
  opacity: 0.85;
  transform: scale(0.99);
}

.search-bar__icon {
  font-size: 32rpx;
}

.search-bar__placeholder {
  font-size: 26rpx;
  color: #a9aeb8;
}

/* 区块 */
.section {
  margin-top: 32rpx;
}

.section__header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2329;
}

.section__tag {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  font-size: 20rpx;
  color: #ff7d00;
  background: #fff7e6;
  border-radius: 16rpx;
}

.loading,
.empty {
  padding: 60rpx 0;
  text-align: center;
  color: #86909c;
  font-size: 26rpx;
}

/* 游戏卡片 */
.game-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.game-card {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.04);
}

.game-card--hover {
  transform: scale(0.98);
}

.game-card__cover {
  width: 200rpx;
  height: 240rpx;
  background: #f2f3f5;
  flex-shrink: 0;
}

.game-card__body {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.game-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.game-card__desc {
  flex: 1;
  font-size: 22rpx;
  color: #86909c;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.game-card__meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.game-card__rating {
  font-size: 24rpx;
  color: #ff9a23;
  font-weight: 600;
}

.game-card__price {
  margin-left: auto;
  font-size: 26rpx;
  color: #f53f3f;
  font-weight: 600;
}

.game-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.tag {
  padding: 2rpx 12rpx;
  font-size: 20rpx;
  color: #5b3aa8;
  background: #f2f4ff;
  border-radius: 12rpx;
}

/* 底部 */
.footer {
  margin-top: 60rpx;
  padding: 40rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #a9aeb8;
}
