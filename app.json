{
  "pages": [
    "pages/index/index",
    "pages/rank/rank",
    "pages/category/category",
    "pages/mine/mine",
    "pages/mine/favorites/favorites",
    "pages/mine/history/history",
    "pages/mine/setting/setting"
  ],
  "subPackages": [
    {
      "root": "pages/game/",
      "name": "subpkg-game",
      "pages": [
        "detail/detail",
        "list/list"
      ]
    },
    {
      "root": "pages/search/",
      "name": "subpkg-search",
      "pages": [
        "search",
        "result/result"
      ]
    },
    {
      "root": "pages/legal/",
      "name": "subpkg-legal",
      "pages": [
        "agreement/agreement",
        "privacy/privacy"
      ]
    }
  ],
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["subpkg-game", "subpkg-search"]
    },
    "pages/category/category": {
      "network": "all",
      "packages": ["subpkg-game"]
    },
    "pages/rank/rank": {
      "network": "all",
      "packages": ["subpkg-game"]
    },
    "pages/mine/mine": {
      "network": "wifi",
      "packages": ["subpkg-legal"]
    }
  },
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTitleText": "GameCurior",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#f6f7fb"
  },
  "tabBar": {
    "color": "#86909c",
    "selectedColor": "#5b3aa8",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "images/tabbar/home_normal.png",
        "selectedIconPath": "images/tabbar/home_active.png"
      },
      {
        "pagePath": "pages/rank/rank",
        "text": "榜单",
        "iconPath": "images/tabbar/rank_normal.png",
        "selectedIconPath": "images/tabbar/rank_active.png"
      },
      {
        "pagePath": "pages/category/category",
        "text": "分类",
        "iconPath": "images/tabbar/category_normal.png",
        "selectedIconPath": "images/tabbar/category_active.png"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的",
        "iconPath": "images/tabbar/mine_normal.png",
        "selectedIconPath": "images/tabbar/mine_active.png"
      }
    ]
  },
  "style": "v2",
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents",
  "usingComponents": {
    "privacy-popup": "/components/privacy-popup/privacy-popup",
    "skeleton": "/components/skeleton/skeleton",
    "empty-state": "/components/empty-state/empty-state",
    "banner-swiper": "/components/banner-swiper/banner-swiper"
  }
}
